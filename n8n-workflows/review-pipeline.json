{
  "name": "审核提醒流水线",
  "version": 1,
  "active": false,
  "settings": {
    "saveExecutionProgress": true,
    "callerPolicy": "workflowsFromSameOwner"
  },
  "nodes": [
    {
      "id": "n1",
      "name": "每小时检查",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        250,
        300
      ],
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours",
              "hoursInterval": 1
            }
          ]
        }
      }
    },
    {
      "id": "n2",
      "name": "查询待审核",
      "type": "n8n-nodes-base.supabase",
      "typeVersion": 1,
      "position": [
        450,
        300
      ],
      "parameters": {
        "operation": "getAll",
        "tableId": "review_queue",
        "filters": {
          "conditions": [
            {
              "fieldName": "status",
              "condition": "eq",
              "fieldValue": "pending"
            }
          ]
        }
      }
    },
    {
      "id": "n3",
      "name": "有待审核?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        650,
        300
      ],
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{$json.length}}",
              "operation": "larger",
              "value2": 0
            }
          ]
        }
      }
    },
    {
      "id": "n4",
      "name": "飞书通知",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        850,
        300
      ],
      "parameters": {
        "method": "POST",
        "url": "={{$env.FEISHU_WEBHOOK_URL}}",
        "sendBody": true,
        "bodyContentType": "json",
        "bodyText": "{\"msg_type\":\"interactive\",\"card\":{\"header\":{\"title\":{\"tag\":\"plain_text\",\"content\":\"审 核提醒\"}},\"elements\":[{\"tag\":\"div\",\"text\":{\"tag\":\"lark_md\",\"content\":\"当前有 {{$json.length}} 条内容待审核，请登录后台处理。\"}}]}}"
      }
    }
  ],
  "connections": {
    "n1": {
      "main": [
        [
          {
            "node": "n2",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "n2": {
      "main": [
        [
          {
            "node": "n3",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "n3": {
      "true": [
        [
          {
            "node": "n4",
            "type": "main",
            "index": 0
          }
        ]
      ],
      "false": []
    }
  }
}